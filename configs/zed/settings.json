// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "cli_default_open_behavior": "existing_window",
  "context_servers": {
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {}
    }
  },
  "icon_theme": "Material Icon Theme",
  "agent": {
    "dock": "right",
    "default_profile": "write",
    "tool_permissions": {
      "tools": {
        "save_file": {
          "default": "allow"
        },
        "terminal": {
          "default": "allow"
        }
      }
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "gemini-3.1-pro-preview",
      "enable_thinking": false
    },
    "favorite_models": [
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-5",
        "enable_thinking": true
      },
      {
        "provider": "zed.dev",
        "model": "claude-sonnet-4-6",
        "enable_thinking": true,
        "effort": "max"
      },
      {
        "provider": "zed.dev",
        "model": "gpt-5.4",
        "enable_thinking": true,
        "effort": "medium"
      },
      {
        "provider": "zed.dev",
        "model": "gpt-5.3-codex",
        "enable_thinking": true,
        "effort": "medium"
      },
      {
        "provider": "zed.dev",
        "model": "gemini-3.1-pro-preview",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "grok-code-fast-1",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "gemini-3-flash",
        "enable_thinking": false
      },
      {
        "provider": "zed.dev",
        "model": "grok-4",
        "enable_thinking": false
      }
    ],
    "model_parameters": []
  },
  "session": {
    "trust_all_worktrees": true
  },
  "vim_mode": false,
  "buffer_font_family": "Fira Code",
  "agent_servers": {
    "mistral-vibe": {
      "type": "registry"
    },
    "opencode": {
      "type": "registry"
    },
    "qwen-code": {
      "type": "registry"
    },
    "gemini": {
      "favorite_models": [
        "auto-gemini-3"
      ],
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    },
    "cursor": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "base_keymap": "VSCode",
  "ui_font_size": 16,
  "buffer_font_size": 14.0,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Ayu Dark",
  },
}
