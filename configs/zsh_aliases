# Dotfiles Environment Health Check
dot-health() {
  echo "🏥 Dotfiles Health Check"
  echo "========================"
  local tools=("bun" "pnpm" "node" "docker" "nx" "ng" "flutter" "rg" "fd" "gh" "git" "tree")
  for tool in "${tools[@]}"; do
    if command -v "$tool" >/dev/null 2>&1; then
      echo -e "  ✅ $tool is installed"
    else
      echo -e "  ❌ \e[31m$tool is missing\e[0m"
    fi
  done
  echo "========================"
}


