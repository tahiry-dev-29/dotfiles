# CTRL+SHIFT+O — Dynamic directory jump with fzf (Task #10)
# ==============================================================================
_fzf_cd_widget() {
  local selected
  selected=$(find "${FZF_CD_BASE:-$HOME}" -maxdepth ${FZF_CD_DEPTH:-5} -type d \
    -not -path '*/node_modules/*' \
    -not -path '*/.git/*' \
    -not -path '*/.dart_tool/*' \
    -not -path '*/.angular/*' \
    2>/dev/null | fzf --prompt='  Dir: ' --preview 'ls -la {}' --height=50% --reverse)
  if [[ -n "$selected" ]]; then
    BUFFER="cd \"$selected\""
    zle accept-line
  else
    zle reset-prompt
  fi
}
if command -v fzf >/dev/null 2>&1; then
  zle -N _fzf_cd_widget
  # Ctrl+Shift+O (terminal sends ^[[79;6u or \eO with many terms; bind both)
  bindkey '^[o' _fzf_cd_widget          # Alt+O fallback
  bindkey '^[[79;6u' _fzf_cd_widget     # Ctrl+Shift+O (kitty CSI u)
  bindkey '^O' _fzf_cd_widget           # Ctrl+O common mapping
fi

# ==============================================================================
# WORKTREE AUTO-SETUP — copy .env + pnpm install (Task #16)
# ==============================================================================
wt-new() {
  if [[ $# -lt 2 ]]; then
    echo "Usage: wt-new <worktree-path> <branch-name> [base-branch]"
    echo "  e.g. wt-new ../myapp-feature-auth feature/auth main"
    return 1
  fi

  local wt_path="$1"
  local branch="$2"
  local base="${3:-main}"
  local src_root
  src_root=$(git rev-parse --show-toplevel 2>/dev/null)

  if [[ -z "$src_root" ]]; then
    echo "❌ Not inside a git repository."
    return 1
  fi

  echo ""
  echo "╔══════════════════════════════════════════╗"
  echo "║       🌿 Git Worktree Auto-Setup         ║"
  echo "╠══════════════════════════════════════════╣"
  printf "║  Path   : %-31s║\n" "$wt_path"
  printf "║  Branch : %-31s║\n" "$branch"
  printf "║  Base   : %-31s║\n" "$base"
  echo "╚══════════════════════════════════════════╝"

  read -q "REPLY?  [?] Confirm creation? [y/N] "
  echo ""
  if [[ "$REPLY" != "y" ]]; then
    echo "⏭️  Aborted."
    return 0
  fi

  echo "🌿 Creating worktree → $wt_path on branch: $branch"
  git worktree add "$wt_path" -b "$branch" "$base" || {
    echo "❌ Worktree creation failed."
    return 1
  }
  echo "✅ Worktree created."

  # Auto-copy .env files
  local envs_copied=0
  while IFS= read -r -d '' env_file; do
    local rel
    rel=$(realpath --relative-to="$src_root" "$env_file")
    local dest="$wt_path/$rel"
    mkdir -p "$(dirname "$dest")"
    cp "$env_file" "$dest"
    echo "📋 Copied: $rel"
    envs_copied=$((envs_copied + 1))
  done < <(find "$src_root" -maxdepth 4 -name '.env' -not -path '*/node_modules/*' -print0 2>/dev/null)
  echo "✅ $envs_copied .env file(s) copied."

  # Auto-install dependencies
  if [[ -f "$wt_path/pnpm-lock.yaml" ]] || [[ -f "$wt_path/package.json" ]]; then
    echo "📦 Running pnpm install in $wt_path..."
    (
      cd "$wt_path" && pnpm install
    ) && echo "✅ pnpm install complete." || echo "⚠️  pnpm install had issues — check output."
  fi

  echo ""
  echo "🚀 Worktree ready! cd into it with:"
  echo "   cd $wt_path"
  echo ""
}

