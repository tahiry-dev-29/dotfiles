+# ==============================================================================
+#  TAHIRY'S ZSH ALIASES - 2026 EDITION 🚀
+#  Stack: Angular · NestJS · Flutter · Prisma · NX · Docker · Bun · pnpm
+# ==============================================================================
+
+# ── 0. PROFILING (uncomment to debug startup time) ────────────
+# zmodload zsh/zprof   # at the top of .zshrc
+# zprof               # at the bottom of .zshrc
+
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 1. SYSTEM & TOOLS 🛠️
+# ══════════════════════════════════════════════════════════════════════════════
+alias c='clear'
+alias q='exit'
+alias ll='ls -la'
+alias la='ls -A'
+alias l='ls -CF'
+alias ..='cd ..'
+alias ...='cd ../..'
+alias ....='cd ../../..'
+alias ~='cd ~'
+alias -- -='cd -'                     # return to previous directory
+
+alias nv='nvim .'
+alias v='nvim'
+alias grep='rg'                       # ripgrep > grep
+alias df='df -h'
+alias s='sudo '
+# Fast navigation (zoxide)
+alias cd='z'
+alias cdi='zi'                        # fzf interactive mode
+
+# Edit config
+alias zshc="nvim ~/.zshrc"
+alias ld="lazydocker"
+alias lg="lazygit"
+alias tb="taskbook"
+alias zsha="nvim ~/.zsh_aliases"
+alias reload='source ~/.zshrc && echo "🚀 Configuration reloaded!"'
+alias path='echo $PATH | tr ":" "\n" | nl'   # display PATH readably
+
+# System
+alias update='sys-update'
+alias upgrade='sys-upgrade'
+alias upall='sys-upgrade --all'
+alias clean-sys='sys-clean'
+alias mem='free -h'
+
+# Fixes
+alias brave-fix="rm -f ~/.config/BraveSoftware/Brave-Browser/SingletonLock ~/.config/BraveSoftware/Brave-Browser/SingletonCookie"
+alias fix-gpg='gpg --refresh-keys'
+
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 2. SERVICES 🐳
+# ══════════════════════════════════════════════════════════════════════════════
+alias pg-start='echo "🐘 Starting PostgreSQL..." && sudo systemctl start postgresql && echo "✅ PostgreSQL started"'
+alias pg-stop='echo "🐘 Stopping PostgreSQL..." && sudo systemctl stop postgresql && echo "✅ PostgreSQL stopped"'
+alias pg-status='echo "🐘 PostgreSQL status:" && sudo systemctl status postgresql'
+alias pg-restart='echo "🐘 Restarting PostgreSQL..." && sudo systemctl restart postgresql && echo "✅ PostgreSQL restarted"'
+alias pg-log='echo "🐘 Following PostgreSQL logs (Ctrl+C to exit)..." && sudo journalctl -u postgresql -f'
+
+alias mg-start='echo "🍃 Starting MongoDB..." && sudo systemctl start mongod && echo "✅ MongoDB started"'
+alias mg-stop='echo "🍃 Stopping MongoDB..." && sudo systemctl stop mongod && echo "✅ MongoDB stopped"'
+alias mg-status='echo "🍃 MongoDB status:" && sudo systemctl status mongod'
+
+alias re-start='echo "🔴 Starting Redis..." && sudo systemctl start redis-server && echo "✅ Redis started"'
+alias re-stop='echo "🔴 Stopping Redis..." && sudo systemctl stop redis-server && echo "✅ Redis stopped"'
+alias re-cli='echo "🔴 Connecting to Redis CLI..." && redis-cli'
+alias re-flush='echo "⚠️  Flushing all Redis data..." && redis-cli FLUSHALL && echo "🔴 Redis cleared"'
+
+alias dk-start='echo "🐳 Starting Docker..." && sudo systemctl start docker && echo "✅ Docker started"'
+alias dk-stop='echo "🐳 Stopping Docker..." && sudo systemctl stop docker && echo "✅ Docker stopped"'
+alias dk-status='echo "🐳 Docker status:" && sudo systemctl status docker'
+
+# Combos
+alias dev-up='echo "▶ Starting dev stack..." && pg-start && dk-start && re-start && echo "✅ Dev stack started"'
+alias dev-down='echo "■ Stopping dev stack..." && pg-stop && mg-stop && dk-stop && re-stop && echo "🛑 Dev stack stopped"'
+alias dev-break='dev-down && clean-sys && sudo shutdown now'
+
+# Ports
+alias kill3000='fuser -k 3000/tcp && echo "✅ Port 3000 freed"'
+alias kill4200='fuser -k 4200/tcp && echo "✅ Port 4200 freed"'
+alias kill8080='fuser -k 8080/tcp && echo "✅ Port 8080 freed"'
+kill-port() { echo "🔌 Killing port $1..."; fuser -k ${1}/tcp && echo "✅ Port $1 freed"; }
+
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 📋 CLIPBOARD HISTORY (Wayland — wl-clipboard)
+# ══════════════════════════════════════════════════════════════════════════════
+# Functions moved to scripts/zsh_functions.zsh
+alias clip='echo "📋 Current clipboard:" && wl-paste 2>/dev/null || echo "❌ Empty"'
+alias clip-clear='rm -f "$HOME/.cache/clipboard_history.log" && echo "🗑️  Clipboard history cleared."'
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 3. RUNTIME & PACKAGE MANAGERS ⚡
+# ══════════════════════════════════════════════════════════════════════════════
+# Bun
+alias br='bun run'
+alias brd='bun run dev'
+alias brb='bun run build'
+alias brt='bun run test'
+alias bx='bunx'
+alias brm='bun remove'
+
+# pnpm
+alias p='pnpm'
+alias pi='pnpm install'
+alias pa='pnpm add'
+alias pad='pnpm add -D'
+alias prm='pnpm remove'
+alias pe='pnpm exec'
+alias px='pnpm dlx'
+alias pclean='rm -rf node_modules pnpm-lock.yaml && pnpm install'
+alias pup='pnpm update --interactive --latest'
+alias pwhy='pnpm why'                 # why is this package installed?
+
+
+
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 4. AI & LLM 🤖
+# ══════════════════════════════════════════════════════════════════════════════
+alias gg='gemini'
+alias gpt='codex'
+
+# ══════════════════════════════════════════════════════════════════════════════
+# 5. UTILS & PRODUCTIVITY 🌳
+# ══════════════════════════════════════════════════════════════════════════════
+alias tree-pro='tree -L 10 -I "node_modules|build|dist|.dart_tool|.git|docs|ios|android|.next|.nx|.angular|coverage"'
+alias tree-src='tree -L 5 -I "node_modules|build|dist|.dart_tool|.git" --dirsfirst'
+
+# Network
+alias ping='ping -c 5'
+
+# Find quickly
+alias rgs='rg --type ts'             # ripgrep on TS files
+
+# GNOME Backup
+alias gnome-backup='~/dotfiles/scripts/gnome-dconf.sh'
+
+# ==============================================================================
+# ADVANCED FUNCTIONS
+# ==============================================================================
+
+alias count-ts='count-code ts'
+alias count-dart='count-code dart'
+alias count-html='count-code html'
+
+# Create folder and enter
+mkcd() { mkdir -p "$1" && cd "$1"; }
+
+alias Compress='compress'
+alias Extract='extract'
+
+# Quick backup of a file
+bak() { echo "💾 Backing up $1..."; cp "$1" "$1.bak.$(date +%Y%m%d_%H%M%S)" && echo "✅ Backup: $1.bak"; }
+
+# Find processes eating RAM
+topmem() { echo "🔍 Top RAM usage:"; ps aux --sort=-%mem | head -${1:-15}; }
+topcpu() { echo "🔍 Top CPU usage:"; ps aux --sort=-%cpu | head -${1:-15}; }
+
+# Show env variables from a .env
+dotenv-show() { echo "📄 Showing env variables from ${1:-.env}:"; cat ${1:-.env} | grep -v '^#' | grep -v '^$' | sort; }
+
+# Reload config without losing session
+alias reload-safe='exec zsh'
+
+
+# ==============================================================================
+# 🧩 OPTIONAL MODULES (Sourced if enabled during installation)
+# ==============================================================================
+safe_source() {
+  if [ -f "$1" ]; then
+    if zsh -n "$1" >/dev/null 2>&1; then
+      source "$1"
+    else
+      echo "⚠️ Syntax error in $1. File not sourced."
+    fi
+  fi
+}
+
+safe_source ~/.angular_aliases.zsh
+safe_source ~/.docker_aliases.zsh
+safe_source ~/.flutter_aliases.zsh
+safe_source ~/.nestjs_prisma_aliases.zsh
+safe_source ~/.git_aliases.zsh
+
+# ==============================================================================
+# CTRL+SHIFT+O — Dynamic directory jump with fzf (Task #10)
+# ==============================================================================
+_fzf_cd_widget() {
+  local selected
+  selected=$(find "${FZF_CD_BASE:-$HOME}" -maxdepth ${FZF_CD_DEPTH:-5} -type d \
+    -not -path '*/node_modules/*' \
+    -not -path '*/.git/*' \
+    -not -path '*/.dart_tool/*' \
+    -not -path '*/.angular/*' \
+    2>/dev/null | fzf --prompt='  Dir: ' --preview 'ls -la {}' --height=50% --reverse)
+  if [[ -n "$selected" ]]; then
+    BUFFER="cd \"$selected\""
+    zle accept-line
+  else
+    zle reset-prompt
+  fi
+}
+if command -v fzf >/dev/null 2>&1; then
+  zle -N _fzf_cd_widget
+  # Ctrl+Shift+O (terminal sends ^[[79;6u or \eO with many terms; bind both)
+  bindkey '^[o' _fzf_cd_widget          # Alt+O fallback
+  bindkey '^[[79;6u' _fzf_cd_widget     # Ctrl+Shift+O (kitty CSI u)
+  bindkey '^O' _fzf_cd_widget           # Ctrl+O common mapping
+fi
+
+# ==============================================================================
+# LOAD COMPLEX FUNCTIONS FROM SCRIPTS FOLDER
+# ==============================================================================
+safe_source ~/dotfiles/scripts/zsh_functions.zsh
+
+# ==============================================================================
+# END - Loaded successfully 🎉
+# ==============================================================================
+# echo "  🚀 Aliases Tahiry loaded — $(date +%H:%M)"
